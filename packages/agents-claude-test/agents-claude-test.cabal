cabal-version:      3.0
name:               agents-claude-test
version:            0.1.0.0
synopsis:           Test executable for the agents-claude provider
build-type:         Simple

common warnings
    ghc-options: -Wall

executable agents-claude-test
    import:           warnings

    main-is:          Main.hs

    build-depends:
        base >= 4.18 && < 5,
        agents-core,
        agents-claude,
        aeson >= 2.0 && < 2.3,
        bytestring >= 0.11 && < 0.13,
        conduit >= 1.3 && < 1.4,
        effectful >= 2.4 && < 2.6,
        text >= 1.2 && < 2.2,
        vector >= 0.12 && < 0.14,
        directory >= 1.3 && < 1.5

    hs-source-dirs:   app
    default-language: GHC2024
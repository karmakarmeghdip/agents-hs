cabal-version:      3.0
name:               agents-core
version:            0.1.0.0
synopsis:           Generic LLM provider abstraction for Haskell
description:
  A provider-agnostic abstraction layer for LLM interactions.
  Defines the Provider typeclass, message types, tool definitions,
  streaming events, and structured output schema derivation.
  Similar in spirit to the Vercel AI SDK for TypeScript.

license:            BSD-3-Clause
license-file:       LICENSE
author:             karmakarmeghdip
maintainer:         karmakarmeghdip@gmail.com
build-type:         Simple

common warnings
    ghc-options: -Wall

library
    import:           warnings

    exposed-modules:
        Agents.Error
        Agents.Types
        Agents.StreamEvent
        Agents.Tool
        Agents.Schema
        Agents.Provider

    build-depends:
        base >= 4.18 && < 5,
        aeson >= 2.0 && < 2.3,
        conduit >= 1.3 && < 1.4,
        effectful >= 2.4 && < 2.6,
        text >= 1.2 && < 2.2,
        bytestring >= 0.11 && < 0.13,
        unordered-containers >= 0.2 && < 0.3,
        vector >= 0.12 && < 0.14,
        containers >= 0.6 && < 0.8,
        transformers >= 0.5 && < 0.7

    hs-source-dirs:   src
    default-language: GHC2024